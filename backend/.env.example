# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/property_platform_dev

# Server
PORT=3001
NODE_ENV=development

# JWT Authentication
JWT_SECRET=your-jwt-secret-change-in-production
JWT_REFRESH_SECRET=your-jwt-refresh-secret-change-in-production

# AI Lease Abstraction
AI_PROVIDER=openai
OPENAI_API_KEY=sk-your-key-here
ANTHROPIC_API_KEY=sk-ant-your-key-here

# DocuSign
DOCUSIGN_CLIENT_ID=your-client-id
DOCUSIGN_CLIENT_SECRET=your-client-secret
DOCUSIGN_INTEGRATION_KEY=your-integration-key
DOCUSIGN_SECRET_KEY=your-secret-key
DOCUSIGN_ACCOUNT_ID=your-account-id
DOCUSIGN_BASE_URL=https://demo.docusign.net/restapi
DOCUSIGN_REDIRECT_URI=http://localhost:3001/api/integrations/docusign/callback

# QuickBooks
QUICKBOOKS_CLIENT_ID=your-client-id
QUICKBOOKS_CLIENT_SECRET=your-client-secret
QUICKBOOKS_REALM_ID=your-realm-id
QUICKBOOKS_BASE_URL=https://sandbox-quickbooks.api.intuit.com
QUICKBOOKS_REDIRECT_URI=http://localhost:3001/api/integrations/quickbooks/callback

# Stripe (for CAM true-up payments)
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key
STRIPE_PUBLISHABLE_KEY=pk_test_your-stripe-publishable-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret

# Cloudflare R2 (S3-compatible file storage)
R2_ACCESS_KEY_ID=your-r2-access-key
R2_SECRET_ACCESS_KEY=your-r2-secret-key
R2_BUCKET=camrecon-documents
R2_ENDPOINT=https://your-account-id.r2.cloudflarestorage.com

# Sentry Error Tracking
SENTRY_DSN=https://your-dsn@sentry.io/your-project-id

# Postmark Email
POSTMARK_SERVER_TOKEN=your-postmark-server-token
POSTMARK_FROM_EMAIL=notifications@yourdomain.com
